generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum NotifType {
  order
  product
  category
  system
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  sku         String        @unique
  brand       String        @default("")
  category    String        @default("")
  price       Float
  salePrice   Float?
  stock       Int           @default(0)
  status      ProductStatus @default(DRAFT)
  vendor      String        @default("")
  featured    Boolean       @default(false)
  moq         Int           @default(1)
  description String        @db.Text
  warranty    String        @default("")
  condition   String        @default("NEW")
  weight      String        @default("")
  tags        String        @default("")
  rating      Float         @default(0)
  soldCount   Int           @default(0)
  currency    String        @default("RWF")
  imageUrl    String?       @db.LongText
  images      String?       @db.LongText
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([category])
  @@index([status])
  @@index([featured])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String   @default("#3B82F6")
  emoji       String   @default("📦")
  createdAt   DateTime @default(now())
}

model Order {
  id           String      @id @default(cuid())
  customer     String
  location     String
  items        String      @db.Text
  subtotal     Float
  transportFee Float       @default(0)
  total        Float
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([customer])
}

model Customer {
  id           String          @id @default(cuid())
  name         String          @unique
  location     String
  orderCount   Int             @default(0)
  totalSpent   Float           @default(0)
  firstOrderAt DateTime
  lastOrderAt  DateTime
  createdAt    DateTime        @default(now())

  orders CustomerOrder[]

  @@index([name])
}

model CustomerOrder {
  id         String   @id @default(cuid())
  customerId String
  items      String   @db.Text
  total      Float
  location   String
  isRetail   Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Notification {
  id        String    @id @default(cuid())
  type      NotifType
  title     String
  body      String    @db.Text
  read      Boolean   @default(false)
  link      String?
  createdAt DateTime  @default(now())

  @@index([read])
  @@index([type])
}
