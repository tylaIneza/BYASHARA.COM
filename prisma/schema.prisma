generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  VENDOR
}

enum ProductStatus {
  DRAFT
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum VendorStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum DeliveryCountry {
  RWANDA
  DRC
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(ADMIN)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor?

  @@index([email])
}

model Vendor {
  id           String       @id @default(cuid())
  userId       String       @unique
  businessName String
  description  String?      @db.Text
  logo         String?
  phone        String
  whatsapp     String
  address      String?
  status       VendorStatus @default(PENDING)
  commissionRate Decimal    @default(5) @db.Decimal(5, 2)
  walletBalance  Decimal    @default(0) @db.Decimal(12, 2)
  totalSales     Decimal    @default(0) @db.Decimal(12, 2)
  rating         Decimal    @default(0) @db.Decimal(3, 2)
  totalReviews   Int        @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  reviews  VendorReview[]

  @@index([status])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  subcategories SubCategory[]
  products      Product[]
}

model SubCategory {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  slug       String   @unique
  image      String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([categoryId])
}

model Product {
  id              String        @id @default(cuid())
  vendorId        String
  categoryId      String
  subCategoryId   String?
  name            String
  slug            String        @unique
  sku             String        @unique
  barcode         String?
  brand           String?
  description     String?       @db.Text
  specifications  Json?
  warranty        String?
  condition       String        @default("NEW")
  status          ProductStatus @default(DRAFT)
  featured        Boolean       @default(false)
  moq             Int           @default(1)
  stock           Int           @default(0)
  weight          Decimal?      @db.Decimal(8, 2)
  dimensions      String?
  tags            String[]
  viewCount       Int           @default(0)
  soldCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?

  vendor      Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category    Category      @relation(fields: [categoryId], references: [id])
  subCategory SubCategory?  @relation(fields: [subCategoryId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]
  priceTiers  PriceTier[]
  flashSaleItems FlashSaleItem[]
  orderItems  WhatsAppOrderItem[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  value     String
  stock     Int      @default(0)
  price     Decimal? @db.Decimal(12, 2)
  image     String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model PriceTier {
  id        String  @id @default(cuid())
  productId String
  minQty    Int
  maxQty    Int?
  price     Decimal @db.Decimal(12, 2)
  currency  String  @default("RWF")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Province {
  id             String          @id @default(cuid())
  name           String          @unique
  country        DeliveryCountry @default(RWANDA)
  shippingFee    Decimal         @db.Decimal(10, 2)
  deliveryDays   Int             @default(3)
  isActive       Boolean         @default(true)

  orders WhatsAppOrder[]
}

model FlashSale {
  id        String   @id @default(cuid())
  name      String
  startAt   DateTime
  endAt     DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items FlashSaleItem[]
}

model FlashSaleItem {
  id          String  @id @default(cuid())
  flashSaleId String
  productId   String
  discount    Decimal @db.Decimal(5, 2)
  salePrice   Decimal @db.Decimal(12, 2)

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([flashSaleId, productId])
}

model WhatsAppOrder {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  customerName String?
  customerPhone String?
  provinceId   String?
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(12, 2)
  currency     String      @default("RWF")
  notes        String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  province Province?           @relation(fields: [provinceId], references: [id])
  items    WhatsAppOrderItem[]
}

model WhatsAppOrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  variant   String?
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  order   WhatsAppOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model VendorReview {
  id        String   @id @default(cuid())
  vendorId  String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  link      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id             String  @id @default(cuid())
  whatsappNumber String  @default("+250780000000")
  currency       String  @default("RWF")
  siteName       String  @default("BYASHARA.COM")
  logo           String?
  taxRate        Decimal @default(0) @db.Decimal(5, 2)
}
